    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.groq.com/openai/v1/chat/completions",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer YOUR_GROQ_API_KEY_HERE"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "{\n  \"model\": \"llama-3.3-70b-versatile\",\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": \"Create Instagram content.\\n\\nReturn STRICT JSON only (no text outside JSON):\\n{\\\"caption\\\":\\\"text without quotes or special characters\\\",\\\"hashtags\\\":\\\"#tag1 #tag2\\\",\\\"visualIdea\\\":\\\"design idea\\\"}\"\n    }\n  ]\n}",
        "options": {}
      },
      "id": "node-004",
      "name": "Generate Content",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [-6064, 528]
    },
    {
      "parameters": {
        "functionCode": "let text = $json.choices[0].message.content;\n\n// clean garbage\ntext = text.replace(/```json/g, '')\n           .replace(/```/g, '')\n           .replace(/\\n/g, '')\n           .trim();\n\ntry {\n  const data = JSON.parse(text);\n  return [{ json: data }];\n} catch (e) {\n  return [{\n    json: {\n      caption: \"Default caption\",\n      hashtags: \"#design #creative\",\n      visualIdea: \"modern instagram design\"\n    }\n  }];\n}"
      },
      "id": "node-005",
      "name": "Parse JSON",
      "type": "n8n-nodes-base.function",
      "position": [-5856, 528],
      "typeVersion": 1
    },
    {
      "parameters": {
        "url": "=https://image.pollinations.ai/prompt/{{encodeURIComponent($json.visualIdea + ' modern instagram ad design, typography, ui ux, behance style ' + $now)}}?width=1080&height=1080",
        "options": {}
      },
      "id": "node-006",
      "name": "Generate Image",
      "type": "n8n-nodes-base.httpRequest",
      "position": [-5664, 528],
      "typeVersion": 4.4
    },
    {
      "parameters": {},
      "id": "node-007",
      "name": "Wait",
      "type": "n8n-nodes-base.wait",
      "position": [-5456, 528],
      "typeVersion": 1.1,
      "webhookId": "REPLACE_WITH_YOUR_WEBHOOK_ID"
    },
    {
      "parameters": {
