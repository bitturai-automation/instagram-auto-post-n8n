        "bodyParameters": {
          "parameters": [
            {
              "name": "image_url",
              "value": "=https://image.pollinations.ai/prompt/{{encodeURIComponent($json.visualIdea + \" modern instagram ad design, bold text overlay, typography, ui ux, behance style \" + Date.now())}}?width=1080&height=1080"
            },
            {
              "name": "caption",
              "value": "={{$json[\"caption\"]}} {{$json[\"hashtags\"]}}"
            },
            {
              "name": "access_token",
              "value": "YOUR_INSTAGRAM_ACCESS_TOKEN_HERE"
            }
          ]
        },
        "options": {}
